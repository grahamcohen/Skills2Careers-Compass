# Normalize line endings using Git's standard auto behaviour:
#   - the repository stores LF
#   - working copies check out with platform-native line endings
#     (CRLF on Windows for the upstream maintainer, LF on macOS/Linux)
#
# Without this, automated/scripted edits (Python read/write, GitHub
# web UI uploads, etc.) drift line endings, producing diffs where
# every line registers as changed and the real content edits get lost
# in the noise.

* text=auto

# Explicit text classifications for files where Git's auto-detection
# may guess wrong:
*.js   text
*.html text
*.css  text
*.json text
*.md   text
*.py   text
*.txt  text

# Binary lock-outs (none currently — Tracer image/binary assets
# would go here if ever added):
# *.png binary
# *.jpg binary
